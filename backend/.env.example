# Server Port
PORT=5001

# Environment mode: development | production
NODE_ENV=development

# MongoDB Atlas connection string
# Get this from your MongoDB Atlas dashboard -> Connect -> Drivers
MONGO_URI=your_mongodb_connection_string_here

# Secret key used to sign JWT auth tokens (use any long random string)
JWT_SECRET_KEY=your_jwt_secret_here

# Stream (Chat & Video) API credentials
# Get these from https://getstream.io/ dashboard after creating an app
STEAM_API_KEY=your_stream_api_key_here
STEAM_API_SECRET=your_stream_api_secret_here